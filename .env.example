# --- PAP BFF (server-side only; never exposed to the browser) ---
# Base URL of the service-policy PDP.
PDP_BASE_URL=http://localhost:8080
# Dev-only: token pasted from the Quarkus Dev UI (http://localhost:8080/q/dev → OIDC).
# Must carry the admin marker for writes (phase 2). Replaced by a
# client_credentials service-account flow before any shared environment.
PDP_SERVICE_TOKEN=

# --- Frontend ---
# Auth adapter: "mock" (dev/tests; blocked in production) | "ricardoqmd-auth" (reference implementation, wired).
# Plug any other OIDC client by adding an adapter file — see src/lib/auth/index.tsx.
NEXT_PUBLIC_AUTH_ADAPTER=mock

# Keycloak (required when NEXT_PUBLIC_AUTH_ADAPTER=ricardoqmd-auth).
# Neutral placeholders — real values belong to each deployment, never to the repo.
NEXT_PUBLIC_KEYCLOAK_URL=https://keycloak.example.com
NEXT_PUBLIC_KEYCLOAK_REALM=example
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=authz-admin
